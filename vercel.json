{
  "rewrites": [
    { "source": "/user/:path*", "destination": "/index.html" },
    { "source": "/place/:path*", "destination": "/index.html" },
    { "source": "/note/:path*", "destination": "/index.html" },
    { "source": "/collection/:path*", "destination": "/index.html" },
    { "source": "/feed", "destination": "/index.html" },
    { "source": "/profile", "destination": "/index.html" },
    { "source": "/search", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "bizim-mekanlar-iota.vercel.app"
        }
      ],
      "destination": "https://bizimmekanlar.com/$1",
      "permanent": true
    }
  ]
}
